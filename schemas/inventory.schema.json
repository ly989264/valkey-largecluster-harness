{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Valkey large-cluster inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "topology_mode", "virtual_azs", "hosts"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "topology_mode": {"enum": ["single_az", "physical_aligned", "interleaved"]},
    "virtual_azs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "host_ids", "node_port_start", "node_port_end", "bus_port_offset"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "host_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "node_port_start": {"type": "integer"},
          "node_port_end": {"type": "integer"},
          "bus_port_offset": {"type": "integer", "minimum": 1}
        }
      }
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "address", "access", "platform", "hardware", "network", "storage"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "address": {"type": "string"},
          "access": {"type": "object"},
          "platform": {"type": "object"},
          "hardware": {"type": "object", "required": ["cpu_model", "cpu_cores", "memory_bytes"]},
          "network": {"type": "object"},
          "storage": {"type": "object"}
        }
      }
    }
  }
}
